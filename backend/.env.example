# Flask Configuration
FLASK_ENV=development
SECRET_KEY=change-this-in-production
JWT_SECRET_KEY=change-this-in-production

# Database Configuration
# Development: sqlite:///nextap_dev.db
# Production (PostgreSQL): postgresql+pg8000://user:password@host:5432/dbname
DATABASE_URL=sqlite:///nextap_dev.db

# Server Configuration
PORT=5000
HOST=0.0.0.0

# CORS Configuration (comma-separated URLs)
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:5173

# Email Configuration (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-not-account-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
MAIL_TEST_RECIPIENT=test@example.com

# Cloudflare Workers AI — FREE 10,000 req/day
CF_ACCOUNT_ID=your-account-id
CF_AI_API_TOKEN=your-api-token
CF_AI_MODEL=@cf/meta/llama-3-8b-instruct
CF_AI_TIMEOUT=30

# AWS S3 Configuration (optional for image uploads)
AWS_S3_BUCKET=nextap-uploads
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-secret-key
