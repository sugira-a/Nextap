{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path].py"
    },
    {
      "source": "/_/backend/api/(.*)",
      "destination": "/api/[...path].py"
    },
    {
      "source": "/health",
      "destination": "/api/[...path].py"
    },
    {
      "source": "/_/backend/health",
      "destination": "/api/[...path].py"
    }
  ]
}